# Copy this file to .env and adjust values as needed.

# Database connection string.
# Examples:
#   SQLite:      sqlite:///data/inventory.db
#   PostgreSQL:  postgresql://user:password@localhost:5432/inventory
DATABASE_URL=sqlite:///data/inventory.db

# Logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Set to true for SQL echoing during development.
DEBUG=false

# Host port mapped to PostgreSQL when running with Docker Compose.
POSTGRES_PORT=15432
